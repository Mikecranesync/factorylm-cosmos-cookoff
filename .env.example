# FactoryLM Vision — Environment Configuration
# Copy this file to .env and fill in your values

# NVIDIA Cosmos (if using NVIDIA hosted API)
NVIDIA_COSMOS_API_KEY=your-key-here

# vLLM endpoint (self-hosted Cosmos Reason2-8B on Vast.ai or similar)
VLLM_BASE_URL=http://your-vast-ai-instance:8000/v1

# PLC connection (Allen-Bradley Micro 820 via Modbus TCP)
PLC_HOST=192.168.1.100
PLC_PORT=502

# VFD connection (ATO GS10 via Modbus TCP)
VFD_HOST=192.168.1.101
VFD_PORT=502
VFD_SLAVE=1

# Pi CompactCom Modbus server (PLC reads from Pi)
PI_COMPACTCOM_PORT=5020

# Video source (0=webcam, or RTSP URL)
VIDEO_SOURCE=0

# Matrix API
MATRIX_URL=http://localhost:8000
